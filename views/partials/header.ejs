<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | kintone擬似AI</title>
  <link rel="stylesheet" href="/static/css/style.css" />
</head>
<body>
  <div class="bg-shape"></div>
  <header class="site-header">
    <div class="brand">kintone擬似AI</div>
    <% if (currentUser) { %>
      <nav>
        <a href="/dashboard">ダッシュボード</a>
        <a href="/apps/manage">kintoneアプリ管理</a>
        <a href="/tokens">APIトークン管理</a>
        <a href="/records/new">1件登録</a>
        <a href="/records/analyze">レコード分析</a>
      </nav>
      <form method="post" action="/auth/logout">
        <button type="submit" class="ghost">ログアウト</button>
      </form>
    <% } %>
  </header>

  <main class="container">
    <% if (error) { %>
      <p class="alert error"><%= error %></p>
    <% } %>
    <% if (message) { %>
      <p class="alert success"><%= message %></p>
    <% } %>
