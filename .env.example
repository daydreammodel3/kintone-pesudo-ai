PORT=3000
SESSION_SECRET=change-this-session-secret
# 32バイト鍵をbase64で指定（推奨）
# 例: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY_BASE64=
# 上記未設定時のローカル開発用フォールバック
TOKEN_ENCRYPTION_PASSPHRASE=local-dev-only

# GitHub Copilot / GitHub Models 互換エンドポイント
COPILOT_API_BASE=https://models.inference.ai.azure.com
COPILOT_MODEL=gpt-4o-mini
COPILOT_TIMEOUT_MS=45000
